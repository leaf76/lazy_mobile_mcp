{
  "name": "lazy_mobile_mcp",
  "version": "0.1.0",
  "description": "Local MCP server for Android/iOS device automation and performance telemetry (ADB, simctl, devicectl, WDA)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lazy-mobile-mcp": "bin/lazy-mobile-mcp.js"
  },
  "files": [
    "bin/",
    "dist/",
    "python/adapters/__init__.py",
    "python/adapters/android_adapter.py",
    "python/adapters/ios_adapter.py",
    "python/errors.py",
    "python/perf_collector.py",
    "python/policy_guard.py",
    "python/requirements.txt",
    "python/storage.py",
    "python/worker.py"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "sh -c 'if [ ! -d .venv ]; then python3 -m venv .venv; fi; ./.venv/bin/python -m pip install -r python/requirements.txt >/dev/null; ./.venv/bin/python -m pytest python/tests'",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm test && npm run test:py"
  },
  "keywords": [
    "mcp",
    "mobile",
    "android",
    "ios",
    "mobile-automation",
    "adb",
    "webdriveragent",
    "simctl",
    "performance-telemetry",
    "model-context-protocol"
  ],
  "author": "leaf76",
  "license": "MIT",
  "homepage": "https://github.com/leaf76/lazy_mobile_mcp#readme",
  "bugs": {
    "url": "https://github.com/leaf76/lazy_mobile_mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leaf76/lazy_mobile_mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
