{
  "name": "lazy_mobile_mcp",
  "version": "0.1.0",
  "description": "Local MCP server for mobile control and performance telemetry",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "python3 -m pytest python/tests",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mobile",
    "android",
    "ios"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
